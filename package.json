{
  "name": "@dreamer/middlewares",
  "version": "1.0.3",
  "description": "HTTP middlewares for Deno/Bun, compatible with @dreamer/server.",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./body-parser": "./src/body-parser.ts",
    "./compression": "./src/compression.ts",
    "./cors": "./src/cors.ts",
    "./csrf": "./src/csrf.ts",
    "./error-handler": "./src/error-handler.ts",
    "./health-check": "./src/health-check.ts",
    "./metrics": "./src/metrics.ts",
    "./performance-analyzer": "./src/performance-analyzer.ts",
    "./rate-limit": "./src/rate-limit.ts",
    "./request-id": "./src/request-id.ts",
    "./request-logger": "./src/request-logger.ts",
    "./request-signature": "./src/request-signature.ts",
    "./request-validator": "./src/request-validator.ts",
    "./response-cache": "./src/response-cache.ts",
    "./security-headers": "./src/security-headers.ts",
    "./static-files": "./src/static-files.ts",
    "./timeout": "./src/timeout.ts"
  },
  "scripts": {
    "test": "bun test tests/",
    "check": "deno check src/mod.ts"
  },
  "dependencies": {
    "@dreamer/i18n": "npm:@jsr/dreamer__i18n@1.0.1",
    "@dreamer/logger": "npm:@jsr/dreamer__logger@1.0.2",
    "@dreamer/middleware": "npm:@jsr/dreamer__middleware@1.0.2",
    "@dreamer/runtime-adapter": "npm:@jsr/dreamer__runtime-adapter@1.0.15",
    "@dreamer/server": "npm:@jsr/dreamer__server@1.0.8",
    "brotli": "1.3.3",
    "pako": "2.1.0"
  },
  "devDependencies": {
    "@dreamer/test": "npm:@jsr/dreamer__test@1.0.11"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "keywords": ["middlewares", "server", "dreamer"]
}
